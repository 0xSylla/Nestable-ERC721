# Copy to .env and fill in values

# Deployer private key (0x-prefixed)
PRIVATE_KEY=0x...

# RPC endpoint
RPC_URL=https://...

# Etherscan / block explorer API key (for --verify)
ETHERSCAN_KEY=...

# (Optional) Override the canonical ERC-6551 registry.
# Only needed for local Anvil without --fork-url.
# ERC6551_REGISTRY=0x...
