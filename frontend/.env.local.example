# WalletConnect project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Deployed contract addresses (fill after running Deploy.s.sol)
NEXT_PUBLIC_CHARACTER_NFT_ADDRESS=0x...
NEXT_PUBLIC_GEAR_NFT_ADDRESS=0x...
NEXT_PUBLIC_SLOT_REGISTRY_ADDRESS=0x...

# Off-chain renderer base URL (renderer/index.js)
NEXT_PUBLIC_RENDERER_URL=http://localhost:3000

# Chain ID to connect to (31337=anvil, 11155111=sepolia, 8453=base)
NEXT_PUBLIC_CHAIN_ID=31337
